datasource db {
	provider = "postgresql"
	url      = env("DATABASE_URL")
}

generator client {
	provider = "prisma-client-js"
}

enum Direction {
  INCOME
  EXPENSE
}

enum Flow {
  INCOME
  EXPENSE
  BOTH
}

enum AssetClass {
  STOCK
  ETF
  MUTUAL_FUND
  BOND
  CRYPTO
  CASH
  REAL_ESTATE
  COMMODITY
  OTHER
}

enum ValuationMethod {
  FIFO
  LIFO
  AVG
}

enum Recurrence {
  WEEKLY
  MONTHLY
  YEARLY
}

enum TradeDirection {
  BUY
  SELL
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  emailVerified DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  passwordHash  String?

  // Relations
  categories   Category[]
  types        Type[]
  transactions Transaction[]
  assets       Asset[]
  holdings     Holding[]
  trades       Trade[]
  budgets      Budget[]
  goals        Goal[]
  platforms    Platform[]
  accounts     Account[]
  sessions     Session[]

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? 
  access_token       String? 
  expires_at         Int? 
  token_type         String? 
  scope              String? 
  id_token           String? 
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Human label (e.g., "Salary", "Rent", "Groceries", "Dividends", "Broker Deposit")
  name      String

  /// Whether this category is for INCOME or EXPENSE flows
  direction Direction

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name, direction])
  @@index([userId, direction, name])
}

model Type {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional secondary classification (e.g., "Fixed", "Variable", "Recurring", "One-off")
  name      String

  /// Whether this type applies to income, expense, or both
  appliesTo Flow      @default(BOTH)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId, appliesTo])
}

model Asset {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional trading symbol/ticker (e.g., AAPL, BTC, VWCE)
  symbol     String?

  /// Display name (e.g., "Apple Inc.", "Bitcoin", "Vanguard FTSE All-World UCITS")
  name       String

  assetClass AssetClass

  /// ISO 4217 currency code of pricing (e.g., "EUR", "USD")
  currency   String      @default("EUR")

  metadata   Json?

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  // Relations
  holdings      Holding[]
  trades        Trade[]
  transactions  Transaction[]

  @@unique([userId, symbol, assetClass])
  @@index([userId, assetClass])
}

model Holding {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  assetId    String
  asset      Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)

  /// Current position size (sum of lots if you later model them)
  quantity   Decimal         @db.Decimal(38, 18)

  /// Average cost per unit (in Asset.currency)
  avgCost    Decimal         @db.Decimal(19, 6)

  /// Where this position is held, e.g. "bybit", "mexc", "trading212", "ibkr", "other"
  platform    String          @default("other")

  /// Optional override ticker for price lookup (e.g. "USOIL_USDT" for OIL(WTI)USDT on MEXC futures)
  priceSymbol String?

  /// Leverage factor: null = 1x (no leverage), 2 = 2×, 3 = 3×, -1 = inverse, -2 = −2×, etc.
  leverage   Int?

  valuation  ValuationMethod @default(FIFO)

  openedAt   DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([userId, assetId, platform])
  @@index([userId])
}

model Transaction {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  typeId      String?
  type        Type?      @relation(fields: [typeId], references: [id], onDelete: SetNull)

  /// Positive numbers; use `direction` to know if it's an inflow or outflow
  amount      Decimal    @db.Decimal(19, 4)

  /// Denormalized for fast filtering; should match `category.direction`
  direction   Direction

  occurredAt  DateTime   @default(now())
  description String?

  // --- OPTIONAL: link transactions to assets for trades/dividends ---
  assetId     String?    // Set for trades or dividends/interest tied to an asset
  asset       Asset?     @relation(fields: [assetId], references: [id], onDelete: SetNull)

  /// Use when `assetId` is set (e.g., trades). For dividends, leave null.
  units       Decimal?    @db.Decimal(38, 18) // quantity bought/sold
  unitPrice   Decimal?    @db.Decimal(19, 6)  // price per unit in Asset.currency
  fees        Decimal?    @db.Decimal(19, 6)  // commissions, taxes, etc.

  /// Recurring transaction settings
  recurrence      Recurrence? // null = one-off
  nextOccurrence  DateTime?   // when to spawn the next copy

  /// If generated from a recurring source, points back to the template
  parentId    String?
  parent      Transaction?  @relation("RecurringChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Transaction[] @relation("RecurringChildren")

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId, occurredAt])
  @@index([userId, direction, occurredAt])
  @@index([userId, categoryId, occurredAt])
  @@index([userId, assetId, occurredAt])
  @@index([userId, recurrence, nextOccurrence])
}

model Platform {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// "bybit" | "mexc" | "trading212" | "ibkr"
  name      String

  /// User-defined label e.g. "Bybit Main", "T212 ISA"
  label     String

  /// AES-256-GCM encrypted API key
  apiKey    String

  /// AES-256-GCM encrypted API secret (null for platforms that don't need one)
  apiSecret String?

  /// Extra config: e.g. { "mode": "live" } for Trading 212
  extra     Json?

  isEnabled Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("platforms")
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  /// Monthly spending limit
  amount     Decimal  @db.Decimal(19, 4)

  /// "YYYY-MM" — e.g. "2025-03"
  month      String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, categoryId, month])
  @@index([userId, month])
}
model Goal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  emoji        String    @default("🎯")
  targetAmount Decimal   @db.Decimal(19, 4)
  savedAmount  Decimal   @db.Decimal(19, 4) @default(0)
  deadline     DateTime?
  color        String    @default("#6366f1")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@map("goals")
}

model Trade {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  assetId   String
  asset     Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)

  direction TradeDirection

  /// Number of units bought or sold (always positive)
  quantity  Decimal        @db.Decimal(38, 18)

  /// Price per unit at execution (in asset currency)
  price     Decimal        @db.Decimal(19, 6)

  /// Commission / fees
  fees      Decimal        @db.Decimal(19, 6) @default(0)

  /// Platform/broker where the trade was executed
  platform  String         @default("other")

  tradedAt  DateTime       @default(now())
  notes     String?

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId, assetId, tradedAt])
  @@index([userId, tradedAt])
  @@map("trades")
}
